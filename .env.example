# ============================================================
# Denarius — Environment Variables
#
# All variables are optional. Copy this file to .env only if
# you want to override the defaults below. The two secrets
# (POSTGRES_PASSWORD, JWT_SECRET) are auto-generated on the
# first run and persisted in a Docker volume — leave them
# commented out unless you have a reason to set them.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_DB=denarius
POSTGRES_USER=denarius
# Auto-generated on first run (32 random chars). Set this only
# if you want to use your own password (e.g. external DB).
# POSTGRES_PASSWORD=your_strong_password_here

# ---- JWT Authentication ----
# Auto-generated on first run (64 hex chars). Changing this
# value invalidates all existing sessions.
# JWT_SECRET=your_at_least_32_random_chars_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Application ----
ENVIRONMENT=production

# CORS allowed origins (comma-separated). Add any hostname or
# VPN address you'll use to reach the app, e.g.:
#   http://localhost:9723,http://denarius.tailnet.ts.net:9723
ALLOWED_ORIGINS=http://localhost:9723

# Host port for the web UI
APP_PORT=9723

# ---- Backups ----
BACKUP_RETAIN_DAYS=30
