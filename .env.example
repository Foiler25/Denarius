# ============================================================
# Denarius — Environment Variables
# Copy this file to .env and fill in the values you want to
# customize. Most settings have sensible defaults and the two
# secrets below are auto-generated on first launch — you do
# NOT need to set them unless you want to supply your own.
# ============================================================

# PostgreSQL
POSTGRES_DB=denarius
POSTGRES_USER=denarius
# Optional — a strong random password is auto-generated on first run
# and stored in a Docker volume. Only set this if you want to use
# your own password (e.g. when connecting an external DB).
# POSTGRES_PASSWORD=your_strong_password_here

# JWT Authentication
# Optional — a random 64-char secret is auto-generated on first run.
# Changing this value invalidates all existing sessions.
# JWT_SECRET=your_at_least_32_random_chars_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Application
ENVIRONMENT=production
# Set to your Tailscale IP or hostname if accessing remotely.
# Separate multiple origins with commas: http://100.x.x.x:9723,http://umbrel.local:9723
ALLOWED_ORIGINS=http://localhost:9723

# App port (exposed on host)
APP_PORT=9723

# Backup retention (days)
BACKUP_RETAIN_DAYS=30
